#!/usr/bin/env bash
# ============================================================
# wpcore — WordPress multi-core manager
# Install: sudo cp wpcore /usr/local/bin/wpcore && sudo chmod +x /usr/local/bin/wpcore
# Config:  /etc/wpcore.conf
# ============================================================

set -euo pipefail

# ── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Load config ─────────────────────────────────────────────
CONFIG_FILE="/etc/wpcore.conf"

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/etc/wpcore.conf
        source "$CONFIG_FILE"
    else
        echo -e "${RED}Error:${RESET} Config file not found: $CONFIG_FILE"
        echo "Create it with: sudo wpcore init"
        exit 1
    fi
}

# ── Helper functions ─────────────────────────────────────────
info()    { echo -e "${CYAN}▸${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*"; }
error()   { echo -e "${RED}✗ Error:${RESET} $*" >&2; }
die()     { error "$*"; exit 1; }

require_root() {
    [[ $EUID -eq 0 ]] || die "This command requires sudo."
}

require_site() {
    local site="$1"
    [[ -d "$SITES_DIR/$site" ]] || die "Site '$site' does not exist in $SITES_DIR"
}

require_core() {
    local ver="$1"
    [[ -d "$CORES_DIR/$ver" ]] || die "Core version '$ver' is not available. Run: wpcore add $ver"
}

# Get the current core version of a site (reads from symlink target)
site_version() {
    local site="$1"
    local sitepath="$SITES_DIR/$site"
    if [[ -L "$sitepath/wp-includes" ]]; then
        local target
        target=$(readlink "$sitepath/wp-includes")
        basename "$(dirname "$target")"
    else
        echo "(no core)"
    fi
}

# List all site directories matching the configured prefix
list_site_dirs() {
    find "$SITES_DIR" -maxdepth 1 -mindepth 1 -type d -name "${SITE_PREFIX}*" \
        | sort | xargs -I{} basename {}
}

# ── COMMANDS ──────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────
cmd_init() {
    info "Initializing wpcore..."

    # Create config file if it doesn't exist
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" << 'CONF'
# ============================================================
# wpcore configuration -- /etc/wpcore.conf
# ============================================================

CORES_DIR="/var/www/wp-cores"
SITES_DIR="/var/www"
SITE_PREFIX="local."
WP_CLI="wp"
PHP="php"
APACHE_USER="www-data"
CONF
        success "Config created: $CONFIG_FILE"
    else
        info "Config already exists: $CONFIG_FILE"
    fi

    # Load config now that it exists
    source "$CONFIG_FILE"

    mkdir -p "$CORES_DIR"
    success "Cores directory ready: $CORES_DIR"

    cmd_install_completion

    success "Done. Edit $CONFIG_FILE to match your setup."
}

# ────────────────────────────────────────────────────────────
cmd_install_completion() {
    local completion_dir="/etc/bash_completion.d"
    local completion_file="$completion_dir/wpcore"
    local script_path
    script_path=$(realpath "$0")

    [[ -d "$completion_dir" ]] || { warn "bash-completion not found, skipping."; return; }

    cat > "$completion_file" << COMPLETION
# wpcore bash completion — auto-generated by wpcore init
# Do not edit manually. Re-run: sudo wpcore install-completion

_wpcore_sites() {
    local config="/etc/wpcore.conf"
    if [[ -f "\$config" ]]; then
        local sites_dir prefix
        sites_dir=\$(grep -E '^SITES_DIR=' "\$config" | cut -d'"' -f2)
        prefix=\$(grep -E '^SITE_PREFIX=' "\$config" | cut -d'"' -f2)
        find "\$sites_dir" -maxdepth 1 -mindepth 1 -type d -name "\${prefix}*" \
            2>/dev/null | xargs -I{} basename {}
    fi
}

_wpcore_cores() {
    local config="/etc/wpcore.conf"
    if [[ -f "\$config" ]]; then
        local cores_dir
        cores_dir=\$(grep -E '^CORES_DIR=' "\$config" | cut -d'"' -f2)
        ls "\$cores_dir" 2>/dev/null | sort -V
    fi
}

_wpcore() {
    local cur prev words
    cur="\${COMP_WORDS[COMP_CWORD]}"
    prev="\${COMP_WORDS[COMP_CWORD-1]}"
    words=("\${COMP_WORDS[@]}")

    local commands="init add remove-core list sites status link unlink switch wp install-completion help"

    if [[ \$COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( \$(compgen -W "\$commands" -- "\$cur") )
        return
    fi

    local cmd="\${words[1]}"

    case "\$cmd" in
        switch|link)
            case \$COMP_CWORD in
                2) COMPREPLY=( \$(compgen -W "\$(_wpcore_sites)" -- "\$cur") ) ;;
                3) COMPREPLY=( \$(compgen -W "\$(_wpcore_cores)" -- "\$cur") ) ;;
            esac
            ;;
        unlink|wp)
            if [[ \$COMP_CWORD -eq 2 ]]; then
                COMPREPLY=( \$(compgen -W "\$(_wpcore_sites)" -- "\$cur") )
            fi
            ;;
        remove-core)
            if [[ \$COMP_CWORD -eq 2 ]]; then
                COMPREPLY=( \$(compgen -W "\$(_wpcore_cores)" -- "\$cur") )
            fi
            ;;
    esac
}

complete -F _wpcore wpcore
COMPLETION

    success "Completion installed: $completion_file"
    info "Run 'source $completion_file' or open a new terminal to activate."
}

# ────────────────────────────────────────────────────────────
cmd_add() {
    local version="${1:-}"
    [[ -n "$version" ]] || die "Specify a version: wpcore add <version>  (e.g. wpcore add 6.9.1)"

    local destdir="$CORES_DIR/$version"

    if [[ -d "$destdir" ]]; then
        warn "Core $version already exists at $destdir"
        read -rp "Overwrite? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }
        rm -rf "$destdir"
    fi

    local url="https://wordpress.org/wordpress-${version}.tar.gz"
    local tmpdir
    tmpdir=$(mktemp -d)
    trap '[[ -n "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

    info "Downloading WordPress $version..."
    wget -q --show-progress -O "$tmpdir/wordpress.tar.gz" "$url" \
        || die "Failed to download: $url"

    info "Extracting..."
    tar -xzf "$tmpdir/wordpress.tar.gz" -C "$tmpdir"

    info "Installing core to $destdir..."
    mv "$tmpdir/wordpress" "$destdir"

    # Remove wp-content — it lives in each site, not in the shared core
    rm -rf "$destdir/wp-content"

    chown -R "$APACHE_USER:$APACHE_USER" "$destdir" 2>/dev/null || true

    # Install the smart dispatcher into this core's wp-load.php
    _install_core_dispatcher "$destdir"

    success "WordPress $version added → $destdir"
}

# ────────────────────────────────────────────────────────────
cmd_remove_core() {
    local version="${1:-}"
    [[ -n "$version" ]] || die "Specify a version: wpcore remove-core <version>"
    [[ -d "$CORES_DIR/$version" ]] || die "Core $version does not exist."

    # Check if any site is currently using this core
    local users=()
    for site in $(list_site_dirs); do
        [[ "$(site_version "$site")" == "$version" ]] && users+=("$site")
    done

    if [[ ${#users[@]} -gt 0 ]]; then
        error "Core $version is currently used by:"
        for s in "${users[@]}"; do echo "    - $s"; done
        die "Switch those sites to a different version before removing this core."
    fi

    read -rp "Delete core $version? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }

    rm -rf "${CORES_DIR:?}/$version"
    success "Core $version removed."
}

# ────────────────────────────────────────────────────────────
cmd_switch() {
    local site="${1:-}"
    local version="${2:-}"
    [[ -n "$site" && -n "$version" ]] \
        || die "Usage: wpcore switch <site> <version>"

    require_site "$site"
    require_core "$version"

    local sitepath="$SITES_DIR/$site"
    local corepath="$CORES_DIR/$version"
    local current
    current=$(site_version "$site")

    if [[ "$current" == "$version" ]]; then
        warn "$site is already using WordPress $version"
        exit 0
    fi

    info "Switching $site: $current → $version"

    # Remove old symlinks
    _remove_symlinks "$sitepath" "$current"

    # Create new symlinks
    _create_symlinks "$sitepath" "$corepath"

    chown -h "$APACHE_USER:$APACHE_USER" \
        "$sitepath/wp-admin" \
        "$sitepath/wp-includes" 2>/dev/null || true

    success "$site → WordPress $version"

    # Offer to run wp core update-db via WP-CLI
    _maybe_db_upgrade "$site" "$sitepath"
    
    # Reload Apache
    _reload_php
}

# ────────────────────────────────────────────────────────────
cmd_link() {
    # Initial linking of a site to a core (for new setups)
    local site="${1:-}"
    local version="${2:-}"
    [[ -n "$site" && -n "$version" ]] \
        || die "Usage: wpcore link <site> <version>"

    require_site "$site"
    require_core "$version"

    local sitepath="$SITES_DIR/$site"
    local corepath="$CORES_DIR/$version"

    # Check for conflicts with real (non-symlink) directories
    for item in wp-admin wp-includes; do
        if [[ -e "$sitepath/$item" && ! -L "$sitepath/$item" ]]; then
            die "Real directory $item/ found in $sitepath.\nMove it first:\n  sudo mv $sitepath/$item /tmp/"
        fi
    done

    _create_symlinks "$sitepath" "$corepath"
    
    # Reload Apache
    _reload_php

    success "$site linked to WordPress $version"
    info "Remember to update wp-config.php if needed."
}

# ────────────────────────────────────────────────────────────
cmd_unlink() {
    local site="${1:-}"
    [[ -n "$site" ]] || die "Usage: wpcore unlink <site>"
    require_site "$site"

    local sitepath="$SITES_DIR/$site"
    local current
    current=$(site_version "$site")

    _remove_symlinks "$sitepath" "$current"
    success "$site unlinked from core."
}

# ────────────────────────────────────────────────────────────
cmd_list_cores() {
    echo -e "\n${BOLD}Available WordPress core versions:${RESET}"
    echo -e "${BLUE}$(printf '─%.0s' {1..40})${RESET}"

    if [[ ! -d "$CORES_DIR" ]] || [[ -z "$(ls -A "$CORES_DIR" 2>/dev/null)" ]]; then
        warn "No core versions installed. Run: wpcore add <version>"
        return
    fi

    # Build a map of which sites use which version
    declare -A used_by
    for site in $(list_site_dirs 2>/dev/null || true); do
        local ver
        ver=$(site_version "$site")
        if [[ "$ver" != "(no core)" ]]; then
            used_by["$ver"]+="$site "
        fi
    done

    for ver in $(ls "$CORES_DIR" | sort -V); do
        local sites_using="${used_by[$ver]:-}"
        if [[ -n "$sites_using" ]]; then
            echo -e "  ${GREEN}$ver${RESET}  ← used by: ${CYAN}$sites_using${RESET}"
        else
            echo -e "  ${YELLOW}$ver${RESET}  (not used)"
        fi
    done
    echo
}

# ────────────────────────────────────────────────────────────
cmd_list_sites() {
    echo -e "\n${BOLD}Local sites:${RESET}"
    echo -e "${BLUE}$(printf '─%.0s' {1..50})${RESET}"

    local sites
    sites=$(list_site_dirs 2>/dev/null || true)

    if [[ -z "$sites" ]]; then
        warn "No sites found with prefix '${SITE_PREFIX}' in $SITES_DIR"
        return
    fi

    echo -e "  ${BOLD}$(printf '%-31s' 'Site')  Core version${RESET}"
    printf "  %-35s %s\n" "────────────────────────────────" "────────────"

    for site in $sites; do
        local ver
        ver=$(site_version "$site")
        if [[ "$ver" == "(no core)" ]]; then
            printf "  %-35s ${RED}%s${RESET}\n" "$site" "$ver"
        else
            printf "  %-35s ${GREEN}%s${RESET}\n" "$site" "$ver"
        fi
    done
    echo
}

# ────────────────────────────────────────────────────────────
cmd_status() {
    cmd_list_cores
    cmd_list_sites
}

# ────────────────────────────────────────────────────────────
cmd_wpcli() {
    # Proxy to wp-cli with the correct --path for the site
    local site="${1:-}"
    [[ -n "$site" ]] || die "Usage: wpcore wp <site> <wp-cli command...>"
    require_site "$site"
    shift
    local sitepath="$SITES_DIR/$site"
    info "wp-cli @ $site"
    sudo -u "$APACHE_USER" "$PHP" "$WP_CLI" --path="$sitepath" "$@"
}

# ── Internal helpers ─────────────────────────────────────────

_create_symlinks() {
    local sitepath="$1"
    local corepath="$2"

    # Ensure this core has the dispatcher installed (idempotent)
    _install_core_dispatcher "$corepath"

    # Directories
    ln -sfn "$corepath/wp-admin"    "$sitepath/wp-admin"
    ln -sfn "$corepath/wp-includes" "$sitepath/wp-includes"

    # PHP files in the core root — symlink everything except:
    #   wp-config.php  — belongs to the site, never touched
    #   wp-load.php    — site gets a real copy (see below), not a symlink
    while IFS= read -r -d '' f; do
        local fname
        fname=$(basename "$f")
        [[ "$fname" == "wp-config.php" ]] && continue
        [[ "$fname" == "wp-load.php"   ]] && continue
        ln -sfn "$f" "$sitepath/$fname"
    done < <(find "$corepath" -maxdepth 1 -name "*.php" -print0)

    # wp-load.php in the site — copy the original (wp-load.php.dist) as a
    # real file so PHP's __DIR__ resolves to the site root, not CORES_DIR.
    # The original already does `define('ABSPATH', __DIR__ . '/')` which is
    # exactly what we need.  We prepend a one-line wpcore marker so unlink
    # can safely identify and remove this managed copy later.
    _copy_wp_load_to_site "$corepath" "$sitepath"
}

# ── Install / refresh the smart dispatcher in a core directory ───────────────
#
# Called automatically by cmd_add and _create_symlinks (idempotent).
#
# What it does:
#   • Backs up the original WP wp-load.php to wp-load.php.dist (once only).
#   • Writes a dispatcher to wp-load.php that, when called directly from the
#     core directory (e.g. by something that skips the site symlink), detects
#     the correct site at runtime via DOCUMENT_ROOT / getcwd() and delegates
#     to that site's own real wp-load.php copy.
# ─────────────────────────────────────────────────────────────────────────────
_install_core_dispatcher() {
    local corepath="$1"
    local dist="$corepath/wp-load.php.dist"
    local dispatcher="$corepath/wp-load.php"

    # One-time backup of the original WP wp-load.php
    if [[ ! -f "$dist" && -f "$dispatcher" ]]; then
        cp "$dispatcher" "$dist"
    fi

    # (Re)write the dispatcher — always overwrite so upgrades pick up changes
    cat > "$dispatcher" << 'PHP'
<?php
/**
 * wpcore dispatcher — wp-load.php  (lives in the shared core directory)
 *
 * Each site that uses this core has a real copy of the original wp-load.php
 * in its own root directory (copied from wp-load.php.dist at link time).
 * Normally WordPress loads that site copy directly and never reaches here.
 *
 * This dispatcher exists for the rare case where something calls wp-load.php
 * via its real path inside the core (e.g. a script that resolves symlinks
 * before including).  It detects which site is being served, then delegates
 * to that site's own wp-load.php so ABSPATH is always set correctly.
 *
 * Detection order:
 *   1. $_SERVER['DOCUMENT_ROOT']  — web request (Apache / Nginx)
 *   2. getcwd()                   — WP-CLI  (sets cwd to --path value)
 *   3. debug_backtrace()          — unusual call stacks / nested includes
 */

// ── Build candidate site directories ────────────────────────────────────────
$_wpcore_candidates = [];

// 1. Web: DOCUMENT_ROOT is the vhost root
if ( ! empty( $_SERVER['DOCUMENT_ROOT'] ) ) {
    $_wpcore_candidates[] = rtrim( $_SERVER['DOCUMENT_ROOT'], '/' );
}

// 2. CLI: WP-CLI sets cwd to the --path argument
$_wpcore_cwd = getcwd();
if ( $_wpcore_cwd && ! in_array( $_wpcore_cwd, $_wpcore_candidates, true ) ) {
    $_wpcore_candidates[] = rtrim( $_wpcore_cwd, '/' );
}

// 3. Backtrace: collect unique non-core directories from the call stack
foreach ( debug_backtrace( DEBUG_BACKTRACE_IGNORE_ARGS ) as $_wpcore_frame ) {
    if ( empty( $_wpcore_frame['file'] ) ) {
        continue;
    }
    $_wpcore_dir = dirname( realpath( $_wpcore_frame['file'] ) );
    if ( strpos( $_wpcore_dir, __DIR__ ) === 0 ) {
        continue; // skip anything inside the core itself
    }
    if ( ! in_array( $_wpcore_dir, $_wpcore_candidates, true ) ) {
        $_wpcore_candidates[] = $_wpcore_dir;
    }
}
unset( $_wpcore_frame, $_wpcore_dir, $_wpcore_cwd );

// ── Delegate to the site's own real wp-load.php ──────────────────────────────
foreach ( $_wpcore_candidates as $_wpcore_site_dir ) {
    $_wpcore_site_load = $_wpcore_site_dir . '/wp-load.php';
    // Make sure we are not loading ourselves (infinite loop guard)
    if ( file_exists( $_wpcore_site_load )
         && realpath( $_wpcore_site_load ) !== __FILE__ ) {
        require $_wpcore_site_load;
        return;
    }
}
unset( $_wpcore_candidates, $_wpcore_site_dir, $_wpcore_site_load );

// ── Could not locate a site ──────────────────────────────────────────────────
if ( PHP_SAPI !== 'cli' ) {
    http_response_code( 500 );
    header( 'Content-Type: text/plain; charset=utf-8' );
}
$_wpcore_doc_root = $_SERVER['DOCUMENT_ROOT'] ?? '(not set)';
die(
    "[wpcore] Cannot locate site wp-load.php from the shared core.\n\n" .
    "DOCUMENT_ROOT : {$_wpcore_doc_root}\n" .
    "cwd           : " . getcwd() . "\n\n" .
    "Make sure the site is linked:  sudo wpcore link <site> <version>\n"
);
PHP

    chown "$APACHE_USER:$APACHE_USER" "$dispatcher" 2>/dev/null || true
    chmod 644 "$dispatcher"
}

# ── Copy the original wp-load.php into the site directory ────────────────────
#
# Copies wp-load.php.dist (the untouched original WP file) into the site root
# as a real file so PHP's __DIR__ resolves to the site directory, keeping
# ABSPATH correct even when many sites share the same core.
# ─────────────────────────────────────────────────────────────────────────────
_copy_wp_load_to_site() {
    local corepath="$1"
    local sitepath="$2"
    local dist="$corepath/wp-load.php.dist"
    local dest="$sitepath/wp-load.php"

    [[ -f "$dist" ]] || die "wp-load.php.dist missing in $corepath — re-run: wpcore add $(basename "$corepath")"

    cp "$dist" "$dest"
    chown "$APACHE_USER:$APACHE_USER" "$dest" 2>/dev/null || true
    chmod 644 "$dest"
}

_remove_symlinks() {
    local sitepath="$1"
    local current_ver="${2:-}"

    # Remove directory symlinks
    for item in wp-admin wp-includes; do
        [[ -L "$sitepath/$item" ]] && rm "$sitepath/$item" || true
    done

    # Remove PHP file symlinks that point into CORES_DIR
    local ref_dir="${current_ver:+$CORES_DIR/$current_ver}"
    if [[ -n "$ref_dir" && -d "$ref_dir" ]]; then
        while IFS= read -r -d '' f; do
            local fname
            fname=$(basename "$f")
            [[ "$fname" == "wp-config.php" ]] && continue  # never touched
            [[ "$fname" == "wp-load.php"   ]] && continue  # real file, handled below
            [[ -L "$sitepath/$fname" ]] && rm "$sitepath/$fname" || true
        done < <(find "$ref_dir" -maxdepth 1 -name "*.php" -print0)
    else
        # Fallback: remove any PHP symlinks pointing into CORES_DIR
        while IFS= read -r -d '' f; do
            local fname
            fname=$(basename "$f")
            [[ "$fname" == "wp-config.php" ]] && continue
            [[ "$fname" == "wp-load.php"   ]] && continue
            if [[ -L "$sitepath/$fname" ]]; then
                local target
                target=$(readlink "$sitepath/$fname")
                [[ "$target" == "$CORES_DIR"* ]] && rm "$sitepath/$fname" || true
            fi
        done < <(find "$sitepath" -maxdepth 1 -name "*.php" -print0)
    fi

    # Remove the managed wp-load.php copy — only if it carries the wpcore
    # marker, so a manually placed wp-load.php is never deleted accidentally.
    local site_wp_load="$sitepath/wp-load.php"
    if [[ -f "$site_wp_load" && ! -L "$site_wp_load" ]]; then
        grep -q 'wpcore-managed' "$site_wp_load" 2>/dev/null \
            && rm -f "$site_wp_load" || true
    fi
}

_maybe_db_upgrade() {
    local site="$1"
    local sitepath="$2"

    if command -v "$WP_CLI" &>/dev/null || command -v wp &>/dev/null; then
        local wp_cmd
        wp_cmd=$(command -v "$WP_CLI" 2>/dev/null || command -v wp)
        echo ""
        read -rp "  Run 'wp core update-db' for $site now? [y/N] " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            sudo -u "$APACHE_USER" "$PHP" "$wp_cmd" \
                --path="$sitepath" core update-db \
                && success "Database updated for $site"
        else
            warn "Remember to run: wpcore wp $site core update-db"
        fi
    else
        warn "wp-cli not found. Run manually: wp --path=$sitepath core update-db"
    fi
}

# ── Reload PHP to flush OPcache after a core switch ──────────────────────────
#
# OPcache caches compiled bytecode by real file path. After switching symlinks
# to a new core the old bytecode remains cached, causing 500 errors until the
# cache is cleared. A graceful reload is enough — no downtime.
#
# Prefers PHP-FPM (reload only the FPM pool) and falls back to Apache reload
# for mod_php setups.
# ─────────────────────────────────────────────────────────────────────────────
_reload_php() {
    # Reload PHP-FPM if running, otherwise reload Apache (mod_php)
    if systemctl is-active --quiet 'php*-fpm' 2>/dev/null; then
        local fpm_service
        fpm_service=$(systemctl list-units --type=service --state=active \
            | grep -oP 'php[^\s]+fpm' | head -1)
        if [[ -n "$fpm_service" ]]; then
            systemctl reload "$fpm_service" \
                && success "OPcache flushed (reloaded $fpm_service)" \
                || warn "Could not reload $fpm_service — reload manually to clear OPcache"
            return
        fi
    fi

    if systemctl is-active --quiet apache2 2>/dev/null; then
        systemctl reload apache2 \
            && success "OPcache flushed (reloaded apache2)" \
            || warn "Could not reload apache2 — reload manually to clear OPcache"
    else
        warn "OPcache not flushed — reload PHP-FPM or Apache manually after switch"
    fi
}

# ── Help ──────────────────────────────────────────────────────
cmd_help() {
    echo -e "
${BOLD}wpcore${RESET} — WordPress multi-core manager

${BOLD}USAGE:${RESET}
  wpcore <command> [arguments]

${BOLD}CORES:${RESET}
  ${CYAN}add <version>${RESET}            Download and install a new WP core version
                           Installs a smart wp-load dispatcher into the core
                           e.g. sudo wpcore add 6.6.2
  ${CYAN}remove-core <version>${RESET}    Remove a core version (only if unused)
  ${CYAN}list${RESET}                     List all available core versions

${BOLD}SITES:${RESET}
  ${CYAN}sites${RESET}                    List all sites and their core versions
  ${CYAN}link <site> <version>${RESET}    Link a site to a core (initial setup)
                           Creates wp-load.php symlink + wp-load.site.php
                           e.g. sudo wpcore link local.site1.com 6.5.5
  ${CYAN}switch <site> <version>${RESET}  Switch a site to a different core version
                           e.g. sudo wpcore switch local.site1.com 6.6.2
  ${CYAN}unlink <site>${RESET}            Unlink a site from its core

${BOLD}WP-CLI:${RESET}
  ${CYAN}wp <site> <command>${RESET}      Run a wp-cli command for a specific site
                           e.g. wpcore wp local.site1.com plugin list
                           e.g. wpcore wp local.site1.com core update-db

${BOLD}OTHER:${RESET}
  ${CYAN}status${RESET}                   Show everything (cores + sites)
  ${CYAN}init${RESET}                     Initialize directories, config and completion
  ${CYAN}install-completion${RESET}       (Re)install bash tab-completion

${BOLD}CONFIG:${RESET}  /etc/wpcore.conf
"
}

# ── Auto-sudo ─────────────────────────────────────────────────
# Commands that require root — re-exec with sudo automatically
_SUDO_CMDS="init add remove-core link unlink switch install-completion"
_cmd="${1:-help}"
if [[ " $_SUDO_CMDS " == *" $_cmd "* ]] && [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

# ── Router ────────────────────────────────────────────────────
case "${1:-help}" in
    help|--help|-h) cmd_help ;;
    init)                cmd_init ;;
    install-completion)  cmd_install_completion ;;
    add)          load_config; cmd_add "${2:-}" ;;
    remove-core)  load_config; cmd_remove_core "${2:-}" ;;
    list)         load_config; cmd_list_cores ;;
    sites)        load_config; cmd_list_sites ;;
    status)       load_config; cmd_status ;;
    link)         load_config; cmd_link "${2:-}" "${3:-}" ;;
    unlink)       load_config; cmd_unlink "${2:-}" ;;
    switch)       load_config; cmd_switch "${2:-}" "${3:-}" ;;
    wp)           load_config; shift; cmd_wpcli "$@" ;;
    *)            error "Unknown command: ${1}"; cmd_help; exit 1 ;;
esac
